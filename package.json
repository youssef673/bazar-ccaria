{
  "name": "bazar-di-zico",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "check:env": "node scripts/check-env.mjs",
    "build": "prisma generate && node -e \"const fs=require('fs'); console.log('CWD:', process.cwd()); console.log('DB exists:', fs.existsSync('./dev.db')); try { console.log('Files:', fs.readdirSync('.')); } catch(e) {} \" && echo 'Skipping next build for test'",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
